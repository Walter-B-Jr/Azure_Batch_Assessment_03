{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "8307808990076254882"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "batlab03",
      "metadata": {
        "description": "Prefix for generated resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    }
  },
  "variables": {
    "suffix": "[uniqueString(resourceGroup().id)]",
    "storageAccountName": "[toLower(format('{0}{1}', parameters('namePrefix'), variables('suffix')))]",
    "batchAccountName": "[toLower(format('{0}ba{1}', parameters('namePrefix'), variables('suffix')))]",
    "poolId": "batch_assessment_03_pool",
    "jobId": "batch_assessment_03_job",
    "contributorRole": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b24988ac-6180-42a0-ab88-20f7382dd24c')]",
    "autoScaleFormula": "$samples = $ActiveTasks.GetSamplePercent(TimeInterval_Minute * 1); $tasks = $samples < 70 ? max(0,$ActiveTasks.GetSample(1)) : max( $ActiveTasks.GetSample(1), avg($ActiveTasks.GetSample(TimeInterval_Minute * 3))); $targetVMs = $tasks > 0 ? $tasks: max(0, $TargetDedicatedNodes / 2); $TargetDedicatedNodes = max(0, min($targetVMs, 10)); $NodeDeallocationOption = taskcompletion;",
    "seedScript": "set -e\r\necho \"Authenticating with managed identity...\"\r\nfor a in 1 2 3 4 5 6; do\r\n  az login --identity -u \"$UAMI_CLIENT_ID\" -o none && break\r\n  echo \"  az login retry $a\"; sleep 15\r\ndone\r\necho \"Logging in to Batch account (shared key)...\"\r\nfor a in 1 2 3 4 5 6; do\r\n  az batch account login -g \"$RG\" -n \"$BATCH_NAME\" --shared-key-auth -o none && break\r\n  echo \"  batch login retry $a (waiting for role propagation)\"; sleep 20\r\ndone\r\necho \"Creating job $JOB_ID...\"\r\naz batch job create --id \"$JOB_ID\" --pool-id \"$POOL_ID\" -o none\r\necho \"Creating tasks...\"\r\nfor i in $(seq 1 10); do\r\n  az batch task create --job-id \"$JOB_ID\" --task-id \"assessment_test_task_$i\" --command-line \"cmd /c echo Processing taskdata$i.txt & ping -n 900 127.0.0.1 >nul\" -o none\r\n  echo \"  created assessment_test_task_$i\"\r\ndone\r\necho \"SEED_DONE\"\r\n"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[if(greater(length(variables('storageAccountName')), 24), substring(variables('storageAccountName'), 0, 24), variables('storageAccountName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Batch/batchAccounts",
      "apiVersion": "2024-07-01",
      "name": "[if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "autoStorage": {
          "storageAccountId": "[resourceId('Microsoft.Storage/storageAccounts', if(greater(length(variables('storageAccountName')), 24), substring(variables('storageAccountName'), 0, 24), variables('storageAccountName')))]"
        },
        "poolAllocationMode": "BatchService",
        "publicNetworkAccess": "Enabled"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', if(greater(length(variables('storageAccountName')), 24), substring(variables('storageAccountName'), 0, 24), variables('storageAccountName')))]"
      ]
    },
    {
      "type": "Microsoft.Batch/batchAccounts/pools",
      "apiVersion": "2024-07-01",
      "name": "[format('{0}/{1}', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')), variables('poolId'))]",
      "properties": {
        "vmSize": "STANDARD_D1_V2",
        "taskSlotsPerNode": 4,
        "deploymentConfiguration": {
          "virtualMachineConfiguration": {
            "imageReference": {
              "publisher": "MicrosoftWindowsServer",
              "offer": "WindowsServer",
              "sku": "2019-datacenter",
              "version": "latest"
            },
            "nodeAgentSkuId": "batch.node.windows amd64"
          }
        },
        "scaleSettings": {
          "autoScale": {
            "formula": "[variables('autoScaleFormula')]",
            "evaluationInterval": "PT5M"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')))]"
      ]
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-seed-id', parameters('namePrefix'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')))]",
      "name": "[guid(resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix'))), variables('contributorRole'))]",
      "properties": {
        "roleDefinitionId": "[variables('contributorRole')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix'))), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix')))]"
      ]
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}-seed', parameters('namePrefix'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix'))))]": {}
        }
      },
      "properties": {
        "sku": "Standard",
        "osType": "Linux",
        "restartPolicy": "Never",
        "containers": [
          {
            "name": "seed",
            "properties": {
              "image": "mcr.microsoft.com/azure-cli:2.61.0",
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": "[json('1.5')]"
                }
              },
              "environmentVariables": [
                {
                  "name": "UAMI_CLIENT_ID",
                  "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix'))), '2023-01-31').clientId]"
                },
                {
                  "name": "RG",
                  "value": "[resourceGroup().name]"
                },
                {
                  "name": "BATCH_NAME",
                  "value": "[if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))]"
                },
                {
                  "name": "POOL_ID",
                  "value": "[variables('poolId')]"
                },
                {
                  "name": "JOB_ID",
                  "value": "[variables('jobId')]"
                }
              ],
              "command": [
                "/bin/bash",
                "-c",
                "[format('echo {0} | base64 -d | tr -d ''\\r'' | bash', base64(variables('seedScript')))]"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')))]",
        "[extensionResourceId(resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))), 'Microsoft.Authorization/roleAssignments', guid(resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix'))), variables('contributorRole')))]",
        "[resourceId('Microsoft.Batch/batchAccounts/pools', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName')), variables('poolId'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-id', parameters('namePrefix')))]"
      ]
    }
  ],
  "outputs": {
    "batchAccountName": {
      "type": "string",
      "value": "[if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))]"
    },
    "batchAccountUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Batch/batchAccounts', if(greater(length(variables('batchAccountName')), 24), substring(variables('batchAccountName'), 0, 24), variables('batchAccountName'))), '2024-07-01').accountEndpoint)]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[if(greater(length(variables('storageAccountName')), 24), substring(variables('storageAccountName'), 0, 24), variables('storageAccountName'))]"
    },
    "poolId": {
      "type": "string",
      "value": "[variables('poolId')]"
    },
    "jobId": {
      "type": "string",
      "value": "[variables('jobId')]"
    }
  }
